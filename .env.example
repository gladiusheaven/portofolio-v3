# ── AI Twin (AldyraAI) configuration ──────────────────────────────────────────
#
# PRODUCTION (recommended): point the frontend at a serverless proxy that holds
# the Gemini key server-side. See worker/gemini-proxy.js for a ready-to-deploy
# Cloudflare Worker. With this set, the key is NEVER shipped to the browser.
VITE_AI_PROXY_URL="https://your-proxy.workers.dev"

# DEV / FALLBACK ONLY: used when VITE_AI_PROXY_URL is not set. This value is
# bundled into the public client build, so anyone can read it — do NOT rely on
# it for the deployed site. Keep it for local development only.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (used for self-referential links).
APP_URL="MY_APP_URL"
